{
  "title": "Greenhouse Data Platform",
  "uid": "greenhouse-main",
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Live Temperature — Facility A",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Greenhouse PostgreSQL",
        "rawSql": "SELECT ROUND(AVG(value)::numeric, 2) FROM live_readings WHERE facility_id = 'facility_A' AND sensor_type = 'temperature' AND is_anomaly = false",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0, "max": 50,
          "thresholds": {
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 20 },
              { "color": "red",   "value": 30 }
            ]
          }
        }
      }
    },
    {
