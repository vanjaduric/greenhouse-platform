    {
      "id": 7,
      "title": "VPD — Last 24 Hours (both facilities)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Greenhouse PostgreSQL",
        "rawSql": "SELECT window_start AS time, facility_id AS metric, avg_vpd AS value FROM fct_30min_climate WHERE window_start > NOW() - INTERVAL '24 hours' ORDER BY window_start",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "title": "Climate Score — Last 24 Hours",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Greenhouse PostgreSQL",
        "rawSql": "SELECT window_start AS time, facility_id AS metric, climate_score AS value FROM fct_30min_climate WHERE window_start > NOW() - INTERVAL '24 hours' ORDER BY window_start",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green",  "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Anomaly Rate — Last 24 Hours",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Greenhouse PostgreSQL",
        "rawSql": "SELECT window_start AS time, facility_id AS metric, overall_anomaly_rate AS value FROM fct_30min_climate WHERE window_start > NOW() - INTERVAL '24 hours' ORDER BY window_start",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 10,
      "title": "Zone Temperature Variance — Last 24 Hours",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Greenhouse PostgreSQL",
        "rawSql": "SELECT window_start AS time, facility_id AS metric, variance_temperature AS value FROM fct_30min_climate WHERE window_start > NOW() - INTERVAL '24 hours' ORDER BY window_start",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 11,
      "title": "Current Anomalies",
      "type": "table",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 6 },
      "targets": [{
        "datasource": "Greenhouse PostgreSQL",
        "rawSql": "SELECT facility_id, sensor_id, sensor_type, value, recorded_at FROM live_readings WHERE is_anomaly = true ORDER BY recorded_at DESC LIMIT 20",
        "format": "table"
      }]
    }
  ]
